{
  "AllowedHosts": "*",

  "Authentication": {
    "ValidIssuer": "https://localhost:8090/"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  "ForwardedHeaders": {
    "AllowedHosts": [],
    "KnownIPNetworks": []
  },

  "ReverseProxy": {
    "Clusters": {
      "apiCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:10202"
          }
        }
      },
      "authCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:10203"
          }
        }
      }
    },
    "Routes": {
      "apiRoute": {
        "AuthorizationPolicy": "anonymous",
        "ClusterId": "apiCluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "authRoute": {
        "AuthorizationPolicy": "anonymous",
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/connect/{**catch-all}"
        }
      },
      "openIdConfigurationRoute": {
        "AuthorizationPolicy": "anonymous",
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/.well-known/{**catch-all}"
        }
      }
    }
  }
}
